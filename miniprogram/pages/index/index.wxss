/**
 * 创作页面样式 - 液态玻璃风格
 */

/* 容器 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #0a0a14 0%, #0f0f1e 30%, #141428 60%, #0a0a14 100%);
  padding: 0 30rpx 40rpx;
  position: relative;
  overflow: hidden;
}

/* 背景光晕 */
.bg-glow {
  position: absolute;
  border-radius: 50%;
  filter: blur(100rpx);
  pointer-events: none;
}

.glow-1 {
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(255, 215, 0, 0.12) 0%, transparent 70%);
  top: -100rpx;
  right: -80rpx;
  animation: float1 12s ease-in-out infinite;
}

.glow-2 {
  width: 350rpx;
  height: 350rpx;
  background: radial-gradient(circle, rgba(100, 100, 255, 0.08) 0%, transparent 70%);
  bottom: 300rpx;
  left: -80rpx;
  animation: float2 15s ease-in-out infinite;
}

@keyframes float1 {
  0%, 100% { transform: translate(0, 0); }
  50% { transform: translate(-30rpx, 30rpx); }
}

@keyframes float2 {
  0%, 100% { transform: translate(0, 0); }
  50% { transform: translate(30rpx, -20rpx); }
}

/* 英雄区域 */
.hero-section {
  text-align: center;
  padding: 50rpx 0 40rpx;
  position: relative;
  z-index: 1;
}

.hero-icon {
  display: block;
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.hero-title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #ffd700;
  text-shadow: 0 0 30rpx rgba(255, 215, 0, 0.4);
  margin-bottom: 10rpx;
}

.hero-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 卡片通用 */
.card {
  margin-bottom: 24rpx;
  padding: 30rpx;
  position: relative;
  z-index: 1;
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #ffd700;
}

/* 故事需求输入 */
.prompt-input {
  width: 100%;
  min-height: 180rpx;
  background: rgba(0, 0, 0, 0.3);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  padding: 24rpx;
  color: #ffffff;
  font-size: 28rpx;
  line-height: 1.8;
  box-sizing: border-box;
  transition: all 0.3s ease;
}

.prompt-input:focus {
  border-color: rgba(255, 215, 0, 0.3);
  box-shadow: 0 0 30rpx rgba(255, 215, 0, 0.1);
}

.input-footer {
  display: flex;
  justify-content: flex-end;
  margin-top: 12rpx;
}

.char-count {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.3);
}

/* 创作模式 */
.mode-summary {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 24rpx;
  padding: 16rpx 20rpx;
  background: rgba(255, 215, 0, 0.05);
  border-radius: 12rpx;
  border-left: 3rpx solid rgba(255, 215, 0, 0.3);
}

.mode-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.mode-card {
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  padding: 24rpx;
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
}

.mode-card.selected {
  border-color: rgba(255, 215, 0, 0.4);
  background: rgba(255, 215, 0, 0.08);
  box-shadow: 
    0 0 30rpx rgba(255, 215, 0, 0.1),
    inset 0 0 30rpx rgba(255, 215, 0, 0.03);
}

.mode-card.selected .mode-indicator {
  opacity: 1;
}

.mode-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.mode-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #ffffff;
}

.mode-nodes {
  font-size: 22rpx;
  color: #ffd700;
  background: rgba(255, 215, 0, 0.15);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 215, 0, 0.2);
}

.mode-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  line-height: 1.6;
}

.mode-indicator {
  position: absolute;
  top: 0;
  right: 0;
  width: 0;
  height: 0;
  border-style: solid;
  border-width: 0 60rpx 60rpx 0;
  border-color: transparent rgba(255, 215, 0, 0.3) transparent transparent;
  opacity: 0;
  transition: opacity 0.3s ease;
}

/* 参数设置 */
.param-grid {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.param-item {
  display: flex;
  align-items: center;
}

.param-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  width: 120rpx;
  flex-shrink: 0;
}

.param-input {
  flex: 1;
  background: rgba(0, 0, 0, 0.3);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 12rpx;
  padding: 18rpx 20rpx;
  color: #ffffff;
  font-size: 28rpx;
  transition: all 0.3s ease;
}

.param-input:focus {
  border-color: rgba(255, 215, 0, 0.3);
  box-shadow: 0 0 20rpx rgba(255, 215, 0, 0.1);
}

.param-slider {
  flex: 1;
  margin: 0 16rpx;
}

/* 快速灵感 */
.chips-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.chip {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 215, 0, 0.15);
  border-radius: 30rpx;
  padding: 16rpx 24rpx;
  transition: all 0.3s ease;
}

.chip:active {
  background: rgba(255, 215, 0, 0.15);
  border-color: rgba(255, 215, 0, 0.4);
  transform: scale(0.95);
}

.chip-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.chip-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 操作区域 */
.action-section {
  margin: 40rpx 0;
  position: relative;
  z-index: 1;
}

.start-btn {
  width: 100%;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  border-radius: 20rpx;
  border: none;
}

.start-btn::after {
  border: none;
}

.start-btn[disabled] {
  background: rgba(255, 215, 0, 0.15);
  color: rgba(255, 215, 0, 0.4);
  box-shadow: none;
}

.btn-icon {
  margin-right: 12rpx;
  font-size: 36rpx;
}

.btn-text {
  font-weight: bold;
}

/* 底部 */
.footer {
  text-align: center;
  padding: 20rpx 0 40rpx;
  position: relative;
  z-index: 1;
}

.divider-glass {
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(255, 215, 0, 0.2), transparent);
  margin-bottom: 24rpx;
}

.footer-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.3);
}
