/* pages/history/history.wxss - 超简版，排除样式问题 */

.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.header {
  background: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border-radius: 10rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.list {
  margin-top: 20rpx;
}

.card {
  background: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border-radius: 10rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-title {
  font-size: 32rpx;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.card-meta {
  font-size: 24rpx;
  color: #999;
}

.btn {
  color: #007aff;
  font-size: 28rpx;
  padding: 10rpx 20rpx;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}

.link {
  color: #007aff;
  margin-top: 20rpx;
  display: block;
}
