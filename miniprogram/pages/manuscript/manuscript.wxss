/**
 * 成稿预览页面样式
 */

/* 容器 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #0a0a14 0%, #0f0f1e 30%, #141428 60%, #0a0a14 100%);
  padding: 20rpx;
  position: relative;
  overflow: hidden;
}

/* 背景光晕 */
.bg-glow {
  position: absolute;
  border-radius: 50%;
  filter: blur(100rpx);
  pointer-events: none;
}

.glow-1 {
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(255, 215, 0, 0.1) 0%, transparent 70%);
  top: -100rpx;
  right: -50rpx;
}

.glow-2 {
  width: 350rpx;
  height: 350rpx;
  background: radial-gradient(circle, rgba(100, 200, 255, 0.08) 0%, transparent 70%);
  bottom: 200rpx;
  left: -50rpx;
}

/* 头部 */
.header {
  margin-bottom: 20rpx;
  position: relative;
  z-index: 1;
}

.header-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 30rpx;
}

.header-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.header-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.header-info {
  flex: 1;
}

.header-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 6rpx;
}

.header-meta {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.header-badge {
  background: rgba(0, 255, 136, 0.15);
  border: 1rpx solid rgba(0, 255, 136, 0.3);
  border-radius: 20rpx;
  padding: 8rpx 20rpx;
}

.badge-text {
  font-size: 22rpx;
  color: #00ff88;
}

/* 成稿区域 */
.manuscript-section {
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx 16rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #ffd700;
}

.word-count {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
}

.manuscript-scroll {
  max-height: 600rpx;
  padding: 0 30rpx 30rpx;
}

.manuscript-content {
  padding: 20rpx 0;
}

.manuscript-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 2;
  letter-spacing: 1rpx;
}

/* 操作按钮 */
.actions-section {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  transition: all 0.3s ease;
}

.action-btn::after {
  border: none;
}

.action-btn:active {
  transform: scale(0.95);
}

.copy-btn {
  background: linear-gradient(135deg, 
    rgba(255, 215, 0, 0.2) 0%, 
    rgba(255, 215, 0, 0.1) 100%
  );
  border: 1rpx solid rgba(255, 215, 0, 0.3);
  color: #ffd700;
}

.share-btn {
  background: linear-gradient(135deg, 
    rgba(0, 255, 136, 0.2) 0%, 
    rgba(0, 255, 136, 0.1) 100%
  );
  border: 1rpx solid rgba(0, 255, 136, 0.3);
  color: #00ff88;
}

.btn-icon {
  margin-right: 12rpx;
  font-size: 32rpx;
}

/* 底部 */
.footer {
  text-align: center;
  padding: 20rpx 0 40rpx;
  position: relative;
  z-index: 1;
}

.footer-tip {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.3);
}
